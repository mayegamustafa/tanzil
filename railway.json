{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": "pnpm start:web"
  },
  "nixpacks": {
    "providers": ["nodejs"],
    "variables": {
      "NIXPACKS_NODE_VERSION": "20"
    },
    "phases": {
      "install": "pnpm install --frozen-lockfile",
      "build": "pnpm build:web"
    }
  }
}
